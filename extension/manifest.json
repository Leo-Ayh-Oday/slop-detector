{
  "manifest_version": 3,
  "name": "AI Slop Detector",
  "version": "1.0.0",
  "description": "Detect AI-generated slop in any GitHub repository with one click.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://github.com/*", "http://localhost:8766/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Slop Detector",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
